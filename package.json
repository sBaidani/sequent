{
  "name": "sequent",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.sequent.app",
    "productName": "Sequent",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon-512x512.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icons/icon-512x512.png",
      "category": "Office"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@solidjs/testing-library": "^0.8.10",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^8.3.4",
    "@formkit/auto-animate": "^0.9.0",
    "@supabase/supabase-js": "^2.106.2",
    "date-fns": "^4.4.0",
