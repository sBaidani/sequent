{
  "name": "sequent",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "start": "npm run build && electron .",
    "sync:android": "npx cap sync android",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.sequent.app",
    "productName": "Sequent",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon-512x512.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icons/icon-512x512.png",
      "category": "Office"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/dompurify": "^3.0.5",
    "autoprefixer": "^10.5.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^8.3.4",
    "@formkit/auto-animate": "^0.9.0",
    "@supabase/supabase-js": "^2.106.2",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.7",
    "idb": "^8.0.3",
    "lucide-solid": "^1.17.0",
    "rrule": "^2.8.1",
    "solid-js": "^1.9.13"
  }
}
